// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User/Customer model
model User {
  id                String      @id @default(cuid())
  telegramId        String      @unique
  firstName         String?
  lastName          String?
  phoneNumber       String?
  email             String?
  altegioUserId     String?     @unique
  locale            String      @default("ru")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?

  // Relations
  appointments      Appointment[]
  notifications     Notification[]
  preferences       UserPreferences?
  loyaltyPoints     LoyaltyPoints?
  aiMessages        AiMessage[]

  @@index([telegramId])
  @@index([altegioUserId])
}

// User preferences
model UserPreferences {
  id                String      @id @default(cuid())
  userId            String      @unique
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  notificationsEnabled    Boolean     @default(true)
  reminderBefore24h       Boolean     @default(true)
  reminderBefore2h        Boolean     @default(true)
  marketingEmails         Boolean     @default(false)
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
}

// Appointments/Bookings
model Appointment {
  id                String      @id @default(cuid())
  telegramUserId    String
  user              User        @relation(fields: [telegramUserId], references: [telegramId])
  
  altegioBookingId  String      @unique
  serviceName       String      // e.g., "Капельница B-комплекс"
  specialist        String?     // Doctor/Specialist name
  
  startTime         DateTime
  endTime           DateTime
  status            String      @default("confirmed") // confirmed, cancelled, completed, no-show
  
  reminder24Sent    Boolean     @default(false)
  reminder2Sent     Boolean     @default(false)
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  // Relations
  notifications     Notification[]

  @@index([telegramUserId])
  @@index([altegioBookingId])
  @@index([startTime])
}

// Notifications log
model Notification {
  id                String      @id @default(cuid())
  telegramUserId    String?
  user              User?       @relation(fields: [telegramUserId], references: [telegramId])
  
  appointmentId     String?
  appointment       Appointment? @relation(fields: [appointmentId], references: [id])
  
  type              String      // confirmation, reminder_24h, reminder_2h, admin_new, admin_cancel
  content           String      // Message text
  locale            String      @default("ru")
  
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failureReason     String?
  retryCount        Int         @default(0)
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([telegramUserId])
  @@index([appointmentId])
  @@index([type])
  @@index([sentAt])
}

// AI assistant interaction log
model AiMessage {
  id                String      @id @default(cuid())
  telegramUserId    String?
  user              User?       @relation(fields: [telegramUserId], references: [telegramId])

  question          String
  answer            String
  mode              String      @default("local") // local, openrouter
  sources           Json?

  createdAt         DateTime    @default(now())

  @@index([telegramUserId])
  @@index([createdAt])
}

// Mailing campaigns
model MailingCampaign {
  id                String      @id @default(cuid())
  title             String
  message           String
  audience          String      // all, marketing_opt_in, active_clients
  status            String      @default("draft") // draft, queued, sent, failed
  recipientCount    Int         @default(0)
  createdBy         String?
  sentAt            DateTime?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([audience])
  @@index([status])
  @@index([createdAt])
}

// Loyalty points
model LoyaltyPoints {
  id                String      @id @default(cuid())
  userId            String      @unique
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  balance           Int         @default(0)
  totalEarned       Int         @default(0)
  totalSpent        Int         @default(0)
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
}

// Queue jobs state (for tracking BullMQ jobs)
model QueueJob {
  id                String      @id @default(cuid())
  queueName         String      // notification, reminder, email, etc
  jobId             String
  status            String      // pending, processing, completed, failed
  
  data              Json
  result            Json?
  error             String?
  
  attemptsMade      Int         @default(0)
  maxAttempts       Int         @default(3)
  
  createdAt         DateTime    @default(now())
  completedAt       DateTime?
  failedAt          DateTime?

  @@unique([queueName, jobId])
  @@index([queueName])
  @@index([status])
}
