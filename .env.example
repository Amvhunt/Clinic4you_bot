# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/clinic_bot

# Redis
REDIS_URL=redis://localhost:6379

# Altegio
ALTEGIO_API_KEY=your_altegio_api_key
ALTEGIO_WEBHOOK_SECRET=your_webhook_secret

# OpenRouter (for AI module)
OPENROUTER_API_KEY=your_openrouter_key

# i18n
DEFAULT_LOCALE=ru
SUPPORTED_LOCALES=ru,ua,en

# Environment
NODE_ENV=development
PORT=3000

# Admin
ADMIN_CHAT_ID=your_admin_chat_id

# Logging
LOG_LEVEL=debug
