# Copy of .env.example for local development
# Update these values before running docker-compose

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.example
DATABASE_URL=postgresql://clinic_user:clinic_password@postgres:5432/clinic_bot
REDIS_URL=redis://redis:6379
ALTEGIO_PARTNER_TOKEN=your_altegio_partner_token
ALTEGIO_USER_TOKEN=your_altegio_user_token
ALTEGIO_LOCATION_ID=your_altegio_location_id
ALTEGIO_WEBHOOK_SECRET=your_webhook_secret
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=openai/gpt-4o-mini
AI_ENABLED=true
DEFAULT_LOCALE=ru
SUPPORTED_LOCALES=ru,ua,en
NODE_ENV=development
PORT=3000
ADMIN_CHAT_ID=your_admin_chat_id
LOG_LEVEL=debug
