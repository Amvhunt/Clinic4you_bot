{
  "name": "clinic-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bot for clinic with notifications, AI support and mini app",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.14",
    "typescript": "^5.3.3"
  },
  "workspaces": [
    "apps/*",
    "modules/*",
    "shared",
    "shared/*",
    "database"
  ],
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2"
  }
}
